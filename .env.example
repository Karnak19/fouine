# fouine configuration. Copy to .env and fill in.

# --- Server ---
PORT=3000
# Log level: debug | info (default) | warn | error. Use debug to see why a
# webhook handler early-returned (e.g. a /review that didn't fire).
LOG_LEVEL=info
# --- Dashboard login (GitHub OAuth) ---
# Protects the dashboard and /api. Login is DISABLED unless BETTER_AUTH_SECRET,
# GITHUB_APP_CLIENT_ID and GITHUB_APP_CLIENT_SECRET are all set. /webhook/github
# and /health are always exempt.
# Random string used to sign sessions: `openssl rand -base64 32`.
BETTER_AUTH_SECRET=
# Public origin of the app, e.g. https://fouine.example.com (no trailing slash).
# Defaults to http://localhost:$PORT for local dev.
BETTER_AUTH_URL=
# Comma-separated GitHub usernames allowed to sign in (case-insensitive).
# Anyone not listed is rejected at first sign-in. Leave empty to allow no one.
ALLOWED_GITHUB_USERS=

# --- GitHub App ---
# Required to receive webhooks and post reviews.
GITHUB_APP_ID=
# Paste the private key with literal \n (fouine un-escapes them), OR use the
# *_PATH variant below and mount the .pem file instead (recommended).
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_PRIVATE_KEY_PATH=
GITHUB_WEBHOOK_SECRET=
# OAuth credentials of the SAME App (General > Client ID / generate a secret),
# reused for dashboard login. Requires callback URL
# $BETTER_AUTH_URL/api/auth/callback/github and Account permission
# "Email addresses: read-only" (GitHub Apps derive email from permissions).
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=

# --- OpenCode (model provider) ---
# opencode-go API key. Injected into the in-process opencode server at review
# time via auth.set, so it works on any host without a local opencode auth store.
OPENCODE_API_KEY=
# Optional: override the default model "opencode-go/glm-5.2".
OPENCODE_MODEL=opencode-go/glm-5.2
